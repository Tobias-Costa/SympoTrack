# ==============================================================================
# DJANGO CORE SETTINGS
# ==============================================================================
# Set to 1 (True) for development, 0 (False) for production
DEBUG=1

# Leave blank or generate a secure random string for development/production
DJANGO_SECRET_KEY=django-insecure-change-me-in-production-1234567890

# Comma-separated list of host/domain names that this Django site can serve
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0


# ==============================================================================
# DATABASE SETTINGS (PostgreSQL)
# ==============================================================================
DB_NAME=sympo_track_db_dev
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Use 'db' if running inside Docker Compose, or 'localhost' if running native
DB_HOST=db
DB_PORT=5432

# ==============================================================================
# DATABASE SETTINGS (Redis)
# ==============================================================================
REDIS_URL = redis://redis:6379/0

# ==============================================================================
# THIRD-PARTY API KEYS
# ==============================================================================
# Get your API key from https://geoapify.com
GEOAPIFY_API_KEY=your_geoapify_api_key_here
